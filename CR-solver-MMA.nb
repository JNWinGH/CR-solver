Cell[BoxData[{
 RowBox[{
  RowBox[{"\[CapitalOmega]GWrexa", "=", 
   RowBox[{
    RowBox[{
     RowBox[{"NIntegrate", "[", 
      RowBox[{
       RowBox[{
        FractionBox["1", "12"], "*", 
        SuperscriptBox[
         RowBox[{"(", 
          FractionBox[
           RowBox[{"t", 
            RowBox[{"(", 
             RowBox[{"2", "+", "t"}], ")"}], 
            RowBox[{"(", 
             RowBox[{
              SuperscriptBox["s", "2"], "-", "1"}], ")"}]}], 
           RowBox[{
            RowBox[{"(", 
             RowBox[{"1", "-", "s", "+", "t"}], ")"}], 
            RowBox[{"(", 
             RowBox[{"1", "+", "s", "+", "t"}], ")"}]}]], ")"}], "2"], "*", 
        RowBox[{"T", "[", 
         RowBox[{"s", ",", "t"}], "]"}], "*", 
        RowBox[{"PRexa", "[", 
         RowBox[{
          RowBox[{
           FractionBox[
            RowBox[{"s", "+", "t", "+", "1"}], "2"], "*", "#", "*", "kstar"}],
           ",", "\[Beta]", ",", "AIR", ",", "\[Tau]s", ",", "\[Tau]e"}], 
         "]"}], "*", 
        RowBox[{"PRexa", "[", 
         RowBox[{
          RowBox[{
           FractionBox[
            RowBox[{"t", "-", "s", "+", "1"}], "2"], "*", "#", "*", "kstar"}],
           ",", "\[Beta]", ",", "AIR", ",", "\[Tau]s", ",", "\[Tau]e"}], 
         "]"}]}], ",", 
       RowBox[{"{", 
        RowBox[{"t", ",", "0", ",", "Infinity"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"s", ",", 
         RowBox[{"-", "1"}], ",", "1"}], "}"}], ",", 
       RowBox[{"Method", "->", "\"\<AdaptiveMonteCarlo\>\""}], ",", 
       RowBox[{"WorkingPrecision", "->", "10"}]}], "]"}], "&"}], "/@", 
    "\[Kappa]slist"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"\[CapitalOmega]GW0exa", "=", 
    RowBox[{"1.6", "*", 
     SuperscriptBox["10", 
      RowBox[{"-", "5"}]], "*", "\[CapitalOmega]GWrexa"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{"plot\[CapitalOmega]GW0exa", "=", 
  RowBox[{"ListLogLogPlot", "[", 
