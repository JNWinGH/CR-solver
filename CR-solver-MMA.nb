Cell[BoxData[
 RowBox[{"\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"\[CapitalOmega]GWrsmo", "=", 
     RowBox[{
      RowBox[{
       RowBox[{"NIntegrate", "[", 
        RowBox[{
         RowBox[{
          FractionBox["1", "12"], "*", 
          SuperscriptBox[
           RowBox[{"(", 
            FractionBox[
             RowBox[{"t", 
              RowBox[{"(", 
               RowBox[{"2", "+", "t"}], ")"}], 
              RowBox[{"(", 
               RowBox[{
                SuperscriptBox["s", "2"], "-", "1"}], ")"}]}], 
             RowBox[{
              RowBox[{"(", 
               RowBox[{"1", "-", "s", "+", "t"}], ")"}], 
              RowBox[{"(", 
               RowBox[{"1", "+", "s", "+", "t"}], ")"}]}]], ")"}], "2"], "*", 
          
          RowBox[{"T", "[", 
           RowBox[{"s", ",", "t"}], "]"}], "*", 
          RowBox[{"Psmo", "[", 
           RowBox[{
            RowBox[{
             FractionBox[
              RowBox[{"s", "+", "t", "+", "1"}], "2"], "*", "#", "*", 
             "kstar"}], ",", "\[Beta]", ",", "AIR", ",", "\[Tau]s", ",", 
            "\[Tau]e", ",", "k1stpk", ",", "k2ndpk"}], "]"}], "*", 
          RowBox[{"Psmo", "[", 
           RowBox[{
            RowBox[{
             FractionBox[
              RowBox[{"t", "-", "s", "+", "1"}], "2"], "*", "#", "*", 
             "kstar"}], ",", "\[Beta]", ",", "AIR", ",", "\[Tau]s", ",", 
            "\[Tau]e", ",", "k1stpk", ",", "k2ndpk"}], "]"}]}], ",", 
         RowBox[{"{", 
          RowBox[{"t", ",", "0", ",", "Infinity"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"s", ",", 
           RowBox[{"-", "1"}], ",", "1"}], "}"}], ",", 
         RowBox[{"Method", "->", "\"\<AdaptiveMonteCarlo\>\""}], ",", 
         RowBox[{"WorkingPrecision", "->", "10"}]}], "]"}], "&"}], "/@", 
      "\[Kappa]slist"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"\[CapitalOmega]GW0smo", "=", 
     RowBox[{"1.6", "*", 
      SuperscriptBox["10", 
       RowBox[{"-", "5"}]], "*", "\[CapitalOmega]GWrsmo"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"plot\[CapitalOmega]GW0smo", "=", 
    RowBox[{"ListLogLogPlot", "[", 
     RowBox[{
      RowBox[{"Transpose", "[", 
       RowBox[{"{", 
        RowBox[{"\[Kappa]slist", ",", 
         RowBox[{"GaussianFilter", "[", 
          RowBox[{"\[CapitalOmega]GW0smo", ",", "1.5"}], "]"}]}], "}"}], 
       "]"}], ",", 
      RowBox[{"Joined", "\[Rule]", "True"}], ",", 
      RowBox[{"Frame", "\[Rule]", "True"}], ",", 
      RowBox[{"PlotStyle", "\[Rule]", "Red"}], ",", 
      RowBox[{"FrameLabel", "\[Rule]", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"Row", "[", 
          RowBox[{"{", 
           RowBox[{"Style", "[", 
            RowBox[{"\"\<\!\(\*TemplateBox[<|\"boxes\" -> FormBox[
RowBox[{
StyleBox[\"k\", \"TI\"], \"/\", 
SubscriptBox[
StyleBox[\"k\", \"TI\"], \"*\"]}], TraditionalForm], \"errors\" -> {}, \
\"input\" -> \"k/k_*\", \"state\" -> \
\"Boxes\"|>,\"TeXAssistantTemplate\"]\)\>\"", ",", "Italic"}], "]"}], "}"}], 
          "]"}], ",", "\"\<\!\(\*SubscriptBox[\(\[CapitalOmega]\), \
\(GW\)]\)\!\(\*SuperscriptBox[\(h\), \(2\)]\)\>\""}], "}"}]}], ",", 
      RowBox[{"GridLines", "->", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"1", ",", 
           RowBox[{
            RowBox[{"-", "k1stpk"}], "*", "\[Tau]s"}], ",", 
           RowBox[{
            RowBox[{"-", "k2ndpk"}], "*", "\[Tau]s"}]}], "}"}], ",", "None"}],
         "}"}]}], ",", 
      RowBox[{"LabelStyle", "\[Rule]", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"FontSize", "\[Rule]", "20"}], ",", 
         RowBox[{"FontFamily", "\[Rule]", "\"\<Times New Roman\>\""}], ",", 
         "Black"}], "}"}]}], ",", 
      RowBox[{"LabelStyle", "\[Rule]", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"FontSize", "\[Rule]", "20"}], ",", 
         RowBox[{"FontFamily", "\[Rule]", "\"\<Times New Roman\>\""}], ",", 
         "Black"}], "}"}]}], ",", 
      RowBox[{"ImageSize", "->", "500"}], ",", 
      RowBox[{"AspectRatio", "->", 
       RowBox[{"3", "/", "5"}]}]}], "]"}]}]}]}]], "Input",
 CellChangeTimes->{{3.979527687393659*^9, 3.9795276886847467`*^9}, 
