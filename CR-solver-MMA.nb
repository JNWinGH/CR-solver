Cell[BoxData[
 RowBox[{"\[IndentingNewLine]", 
  RowBox[{"LogLogPlot", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"PRexa", "[", 
       RowBox[{
        RowBox[{"\[Kappa]s", "*", "kstar"}], ",", "\[Beta]", ",", "AIR", ",", 
        "\[Tau]s", ",", "\[Tau]e"}], "]"}], ",", 
