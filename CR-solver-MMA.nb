Cell[BoxData[
 RowBox[{"\[IndentingNewLine]", 
  RowBox[{"(*", " ", 
   RowBox[{
   "Wavenumber", " ", "of", " ", "the", " ", "first", " ", "peak", " ", "in", 
    " ", "the", " ", "curvature", " ", "perturbation", " ", "power", " ", 
    "spectrum"}], " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"k1stpk", "=", 
    RowBox[{
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"A2A1", "<", "1"}], ",", "khighest", ",", 
       RowBox[{"khighest", "/", "k2k1"}]}], "]"}], "//", "N"}]}], 
   "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Wavenumber", " ", "of", " ", "the", " ", "second", " ", "peak", " ", 
     "in", " ", "the", " ", "curvature", " ", "perturbation", " ", "power", " ",
      "spectrum"}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"k2ndpk", "=", 
     RowBox[{"k1stpk", "*", "k2k1"}]}], ";"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{"beta", ":", 
      RowBox[{
       RowBox[{"Half", " ", "of", " ", "the", " ", "second", " ", "slow"}], "-", 
       RowBox[{"roll", " ", 
        RowBox[{"parameter", ".", " ", "Should"}], " ", "be", " ", 
        "between"}], "-", 
       RowBox[{"3", " ", "and"}], "-", "2"}]}], ",", " ", 
     RowBox[{
     "values", " ", "outside", " ", "this", " ", "range", " ", "are", " ", 
      "considered", " ", "unreliable", " ", "as", " ", 
      RowBox[{"solutions", "."}]}]}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{"\[Beta]", "=", 
    RowBox[{
     RowBox[{"Round", "[", 
      RowBox[{
       RowBox[{"solvebeta", "[", 
        RowBox[{"k2k1", ",", "A2A1"}], "]"}], ",", 
       SuperscriptBox["10", 
        RowBox[{"-", "4"}]]}], "]"}], "//", "N"}]}], "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{"NCR", ":", 
     RowBox[{
      RowBox[{"Duration", " ", "of", " ", "the", " ", "constant"}], "-", 
      RowBox[{"roll", " ", 
       RowBox[{"stage", "."}]}]}]}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{"NCR", "=", 
    RowBox[{"solveNCR", "[", 
     RowBox[{"k2k1", ",", "A2A1"}], "]"}]}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{"Time", " ", "of", " ", "the", " ", "SR"}], "-", 
     RowBox[{"CR", " ", "transition"}]}], " ", "*)"}], "\[IndentingNewLine]", 
   
   RowBox[{"\[Tau]s", "=", 
    RowBox[{"-", 
     FractionBox[
      RowBox[{"x1stpk", "[", "\[Beta]", "]"}], "k1stpk"]}]}], 
   "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{"-", "1"}], "/", "tau_s"}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{"kstar", "=", 
    RowBox[{
     RowBox[{"-", "1"}], "/", "\[Tau]s"}]}], "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{"Time", " ", "of", " ", "the", " ", "CR"}], "-", 
     RowBox[{"SR", " ", "transition"}]}], " ", "*)"}], "\[IndentingNewLine]", 
   
   RowBox[{"\[Tau]e", "=", 
    RowBox[{"-", 
     FractionBox[
      RowBox[{"x2ndpk", "[", "\[Beta]", "]"}], "k2ndpk"]}]}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"\[Kappa]s", "=", 
     RowBox[{
      RowBox[{
       RowBox[{"-", "k"}], " ", "\[Tau]s"}], " ", "=", 
      RowBox[{"k", "/", "kstar"}]}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"\[Kappa]slist", "=", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"10", "^", "x"}], ",", 
       RowBox[{"{", 
        RowBox[{"x", ",", 
         RowBox[{"Log10", "[", 
          FractionBox[
           RowBox[{"k1stpk", "*", 
            RowBox[{"10", "^", 
             RowBox[{"-", "1"}]}]}], "kstar"], "]"}], ",", 
         RowBox[{"Log10", "[", 
          FractionBox[
           RowBox[{"k2ndpk", "*", 
            RowBox[{"10", "^", "1.5"}]}], "kstar"], "]"}], ",", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{"Log10", "[", 
             FractionBox[
              RowBox[{"k2ndpk", "*", 
               RowBox[{"10", "^", "1.5"}]}], "kstar"], "]"}], "-", 
            RowBox[{"Log10", "[", 
             FractionBox[
              RowBox[{"k1stpk", "*", 
               RowBox[{"10", "^", 
                RowBox[{"-", "1"}]}]}], "kstar"], "]"}]}], ")"}], "/", 
          "150"}]}], "}"}]}], "]"}]}], ";"}], " ", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"f", "=", 
      RowBox[{"1.5", "*", 
       SuperscriptBox["10", 
        RowBox[{"-", "15"}]], "*", "k"}]}], ";"}], "*)"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
    "IR", " ", "power", " ", "spectrum", " ", "amplitude", " ", "calculated", 
     " ", "from", " ", "highest", " ", "peak"}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"AIRhighest", "=", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"Ahighest", "=!=", "None"}], ",", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"A2A1", "<", "1"}], ",", 
         FractionBox["Ahighest", 
          RowBox[{
           RowBox[{"f1", "[", "\[Beta]", "]"}], "*", 
           SuperscriptBox[
            RowBox[{"(", 
             RowBox[{"Exp", "[", 
              RowBox[{"-", "NCR"}], "]"}], ")"}], 
            RowBox[{"6", "+", 
             RowBox[{"4", "\[Beta]"}]}]]}]], ",", 
         FractionBox["Ahighest", 
          RowBox[{
           RowBox[{"f2", "[", "\[Beta]", "]"}], "*", 
           SuperscriptBox[
            RowBox[{"(", 
             RowBox[{"Exp", "[", 
              RowBox[{"-", "NCR"}], "]"}], ")"}], 
            RowBox[{"2", "\[Beta]"}]]}]]}], "]"}], ",", "None"}], "]"}]}], 
    ";"}], "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Power", " ", "spectrum", " ", "amplitude", " ", "at", " ", "IR", " ", 
     "limit"}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{"AIR", "=", 
    RowBox[{
     RowBox[{"AIRmplitude", "[", 
      RowBox[{"AIRinput", ",", "AIRhighest"}], "]"}], "//", "N"}]}], 
   "\[IndentingNewLine]"}]}]], "Input",
