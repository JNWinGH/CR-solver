Cell[TextData[StyleBox["IGW-smoothed",
 Background->RGBColor[0.94, 0.88, 0.94]]], "Title",
 CellChangeTimes->{{3.97952233258525*^9, 3.979522339819276*^9}, {
  3.9796992465898438`*^9, 
  3.979699246773342*^9}},ExpressionUUID->"35e5c3fb-47d9-4a65-a04d-\
342865def47f"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"\[CapitalOmega]GWrsmo", "=", 
     RowBox[{
      RowBox[{
       RowBox[{"NIntegrate", "[", 
        RowBox[{
         RowBox[{
          FractionBox["1", "12"], "*", 
          SuperscriptBox[
           RowBox[{"(", 
            FractionBox[
             RowBox[{"t", 
              RowBox[{"(", 
               RowBox[{"2", "+", "t"}], ")"}], 
              RowBox[{"(", 
               RowBox[{
                SuperscriptBox["s", "2"], "-", "1"}], ")"}]}], 
             RowBox[{
              RowBox[{"(", 
               RowBox[{"1", "-", "s", "+", "t"}], ")"}], 
              RowBox[{"(", 
               RowBox[{"1", "+", "s", "+", "t"}], ")"}]}]], ")"}], "2"], "*", 
          
          RowBox[{"T", "[", 
           RowBox[{"s", ",", "t"}], "]"}], "*", 
          RowBox[{"Psmo", "[", 
           RowBox[{
            RowBox[{
             FractionBox[
              RowBox[{"s", "+", "t", "+", "1"}], "2"], "*", "#", "*", 
             "kstar"}], ",", "\[Beta]", ",", "AIR", ",", "\[Tau]s", ",", 
            "\[Tau]e", ",", "k1stpk", ",", "k2ndpk"}], "]"}], "*", 
          RowBox[{"Psmo", "[", 
           RowBox[{
            RowBox[{
             FractionBox[
              RowBox[{"t", "-", "s", "+", "1"}], "2"], "*", "#", "*", 
             "kstar"}], ",", "\[Beta]", ",", "AIR", ",", "\[Tau]s", ",", 
            "\[Tau]e", ",", "k1stpk", ",", "k2ndpk"}], "]"}]}], ",", 
         RowBox[{"{", 
          RowBox[{"t", ",", "0", ",", "Infinity"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"s", ",", 
           RowBox[{"-", "1"}], ",", "1"}], "}"}], ",", 
         RowBox[{"Method", "->", "\"\<AdaptiveMonteCarlo\>\""}], ",", 
         RowBox[{"WorkingPrecision", "->", "10"}]}], "]"}], "&"}], "/@", 
      "\[Kappa]slist"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"\[CapitalOmega]GW0smo", "=", 
     RowBox[{"1.6", "*", 
      SuperscriptBox["10", 
       RowBox[{"-", "5"}]], "*", "\[CapitalOmega]GWrsmo"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"plot\[CapitalOmega]GW0smo", "=", 
    RowBox[{"ListLogLogPlot", "[", 
     RowBox[{
      RowBox[{"Transpose", "[", 
       RowBox[{"{", 
        RowBox[{"\[Kappa]slist", ",", "\[CapitalOmega]GW0smo"}], "}"}], "]"}],
       ",", 
      RowBox[{"Joined", "\[Rule]", "True"}], ",", 
      RowBox[{"Frame", "\[Rule]", "True"}], ",", 
      RowBox[{"PlotStyle", "\[Rule]", "Red"}], ",", 
      RowBox[{"FrameLabel", "\[Rule]", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"Row", "[", 
          RowBox[{"{", 
           RowBox[{"Style", "[", 
            RowBox[{"\"\<\!\(\*TemplateBox[<|\"boxes\" -> FormBox[
RowBox[{
StyleBox[\"k\", \"TI\"], \"/\", 
SubscriptBox[
